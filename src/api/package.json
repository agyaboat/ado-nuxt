{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#validators/*": "./app/validators/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#database/*": "./database/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.0.1",
    "@adonisjs/eslint-config": "^3.0.0",
    "@adonisjs/prettier-config": "^1.4.5",
    "@adonisjs/tsconfig": "^2.0.0",
    "@japa/assert": "^4.0.1",
    "@japa/plugin-adonisjs": "^5.1.0",
    "@japa/runner": "^4.2.0",
    "@poppinss/ts-exec": "^1.4.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.15.18",
    "eslint": "^9.26.0",
    "hot-hook": "^0.4.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8",
    "vite": "^8.0.0",
    "youch": "^4.1.0"
  },
  "dependencies": {
    "@adonisjs/ally": "^6.0.0",
    "@adonisjs/auth": "^10.0.0",
    "@adonisjs/bouncer": "^4.0.0",
    "@adonisjs/cache": "^2.0.1",
    "@adonisjs/core": "^7.1.1",
    "@adonisjs/cors": "^3.0.0",
    "@adonisjs/drive": "^4.0.0",
    "@adonisjs/lucid": "^22.1.1",
    "@adonisjs/mail": "^10.0.0",
    "@adonisjs/redis": "^10.0.0",
    "@adonisjs/session": "^8.0.0",
    "@adonisjs/shield": "^9.0.0",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/vite": "^5.1.0",
    "@vinejs/vine": "^4.3.0",
    "argon2": "^0.44.0",
    "edge.js": "^6.5.0",
    "luxon": "^3.7.2",
    "mysql2": "^3.16.0",
    "openai": "^6.32.0",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "ua-parser-js": "^2.0.9",
    "uuid": "^13.0.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}